# Path to Obsidian/notes vault containing people/ and task files
NOTES_DIRECTORY="/path/to/your/notes"
# Auto-resolved by setup — no need to edit
PROJECT_DIRECTORY="/path/to/GooseTRM"

# ── Events ──────────────────────────────────────────────────────────
# Luma calendar .ics subscription URL (Subscribe → "Add to Calendar").
# Leave blank until you have it — the events pipeline degrades to empty.
LUMA_ICS_URL=""
# Subdirectory of NOTES_DIRECTORY holding recurring-event notes (frontmatter
# with start/end/day). Defaults to "events" if unset.
NOTES_EVENTS_SUBDIR="events"
# IANA timezone used to resolve "today" and localize event times.
EVENTS_TZ="America/Los_Angeles"
