#!/usr/bin/env bash
set -euo pipefail

# Wrapper around trmnlp via Docker.
# Usage: ./trmnlp <command> [args...]
#   ./trmnlp serve          — start dev server on localhost:4567
#   ./trmnlp init <name>    — scaffold a new plugin
#   ./trmnlp login          — authenticate with TRMNL
#   ./trmnlp clone <n> <id> — clone an existing plugin
#   ./trmnlp push           — upload plugin to TRMNL

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_DIR="$SCRIPT_DIR/plugin"
IMAGE="trmnl/trmnlp"
CONFIG_DIR="$HOME/.config/trmnlp"

mkdir -p "$CONFIG_DIR" "$PLUGIN_DIR"

cmd="${1:-}"

case "$cmd" in
  login)
    # Login needs an interactive terminal and persistent config
    docker run -it \
      --volume "$CONFIG_DIR:/root/.config/trmnlp" \
      --volume "$PLUGIN_DIR:/plugin" \
      "$IMAGE" login
    ;;
  serve)
    shift
    SETTINGS="$PLUGIN_DIR/src/settings.yml"
    ORIGINAL_URL=$(grep '^polling_url:' "$SETTINGS" | awk '{print $2}')
    LOCAL_PORT=9473

    # Start a local HTTP server to serve trmnl.json
    python3 -m http.server "$LOCAL_PORT" --directory "$SCRIPT_DIR" &>/dev/null &
    HTTP_PID=$!

    # Point settings.yml at the local server
    sed -i "s|^polling_url:.*|polling_url: http://host.docker.internal:${LOCAL_PORT}/trmnl.json|" "$SETTINGS"

    # Restore original URL and kill HTTP server on exit
    cleanup() {
      sed -i "s|^polling_url:.*|polling_url: ${ORIGINAL_URL}|" "$SETTINGS"
      kill "$HTTP_PID" 2>/dev/null || true
    }
    trap cleanup EXIT

    docker run \
      --publish 4567:4567 \
      --add-host host.docker.internal:host-gateway \
      --volume "$CONFIG_DIR:/root/.config/trmnlp" \
      --volume "$PLUGIN_DIR:/plugin" \
      "$IMAGE" serve "$@"
    ;;
  "")
    echo "Usage: ./trmnlp <command> [args...]"
    echo "Commands: serve, init, login, clone, push"
    exit 1
    ;;
  *)
    # Pass through any other command (init, clone, push, etc.)
    shift
    docker run -it \
      --volume "$CONFIG_DIR:/root/.config/trmnlp" \
      --volume "$PLUGIN_DIR:/plugin" \
      "$IMAGE" "$cmd" "$@"
    ;;
esac
