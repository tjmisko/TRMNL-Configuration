#!/usr/bin/env bash
UA="GooseTRM/1.0 (weather-alerts)"
SF_FORECAST_URL="https://api.weather.gov/gridpoints/MTR/84,105/forecast"
SF_HOURLY_URL="https://api.weather.gov/gridpoints/MTR/84,105/forecast/hourly"
OAK_FORECAST_URL="https://api.weather.gov/gridpoints/MTR/90,106/forecast"
OAK_HOURLY_URL="https://api.weather.gov/gridpoints/MTR/90,106/forecast/hourly"
ALERTS_URL="https://api.weather.gov/alerts/active?zone=CAZ006,CAZ508"

TODAY_23=$(date +"%Y-%m-%dT23:00:00")

extract_forecast() {
  local period_json="$1"
  local hourly_json="$2"
  local cutoff="$3"
  jq -n \
    --argjson periods "$period_json" \
    --argjson hourly "$hourly_json" \
    --arg cutoff "$cutoff" '
    $periods.properties.periods as $p |
    ($p | map(select(.isDaytime == true)) | .[0].temperature) as $high |
    ($p | map(select(.isDaytime == false)) | .[0].temperature) as $low |
    ($hourly.properties.periods
      | map(select(.startTime < $cutoff))
      | map(.probabilityOfPrecipitation.value // 0)
      | max // 0
    ) as $rain_chance |
    {
      high: $high,
      low: $low,
      rain: ($rain_chance >= 30),
      rain_chance: $rain_chance
    }
  '
}

SF_RAW=$(curl -sf -H "User-Agent: $UA" "$SF_FORECAST_URL")
SF_OK=$?
SF_HOURLY_RAW=$(curl -sf -H "User-Agent: $UA" "$SF_HOURLY_URL")
SF_HOURLY_OK=$?
OAK_RAW=$(curl -sf -H "User-Agent: $UA" "$OAK_FORECAST_URL")
OAK_OK=$?
OAK_HOURLY_RAW=$(curl -sf -H "User-Agent: $UA" "$OAK_HOURLY_URL")
OAK_HOURLY_OK=$?
ALERTS_RAW=$(curl -sf -H "User-Agent: $UA" "$ALERTS_URL")

if [ $SF_OK -eq 0 ] && [ $SF_HOURLY_OK -eq 0 ]; then
  SF_FORECAST=$(extract_forecast "$SF_RAW" "$SF_HOURLY_RAW" "$TODAY_23")
else
  SF_FORECAST="null"
fi

if [ $OAK_OK -eq 0 ] && [ $OAK_HOURLY_OK -eq 0 ]; then
  OAK_FORECAST=$(extract_forecast "$OAK_RAW" "$OAK_HOURLY_RAW" "$TODAY_23")
else
  OAK_FORECAST="null"
fi

if [ -n "$ALERTS_RAW" ]; then
  SF_ALERTS=$(echo "$ALERTS_RAW" | jq '[.features[].properties | select(.affectedZones | index("https://api.weather.gov/zones/forecast/CAZ006")) | .event] | unique')
  OAK_ALERTS=$(echo "$ALERTS_RAW" | jq '[.features[].properties | select(.affectedZones | index("https://api.weather.gov/zones/forecast/CAZ508")) | .event] | unique')
else
  SF_ALERTS="[]"
  OAK_ALERTS="[]"
fi

jq -n \
  --argjson sf_forecast "$SF_FORECAST" \
  --argjson oak_forecast "$OAK_FORECAST" \
  --argjson sf_alerts "$SF_ALERTS" \
  --argjson oak_alerts "$OAK_ALERTS" '
  {
    sf: (if $sf_forecast == null then null else ($sf_forecast + {alerts: $sf_alerts}) end),
    oakland: (if $oak_forecast == null then null else ($oak_forecast + {alerts: $oak_alerts}) end)
  }
'
