<div class="layout">
  <div class="columns">
    <div class="column">
      <span class="label">Account dashboard</span>
      <table class="table">
        <thead>
          <tr>
            <th><span class="label label--small">Metric</span></th>
            <th><span class="label label--small">Value</span></th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><span class="title title--small">Subscribers</span></td>
            <td><span class="label">32,117</span></td>
          </tr>
          <tr>
            <td><span class="title title--small">Products Sold</span></td>
            <td><span class="label">137</span></td>
          </tr>
          <tr>
            <td><span class="title title--small">Revenue</span></td>
            <td><span class="label">$12,450</span></td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="column">
      <table class="table">
        <thead>
          <tr>
            <th><span class="label label--small">{{bart|slice:0}}</span></th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><pre class="title--small">{{bart|slice:1}}</pre></td>
          </tr>
          <tr>
            <td><pre class="title--small">{{bart|slice:2}}</pre></td>
          </tr>
          <tr>
            <td><pre class="title--small">{{bart|slice:3}}</pre></td>
          </tr>
          <tr>
            <td><pre class="title--small">{{bart|slice:4}}</pre></td>
          </tr>
          <tr>
            <td><pre class="title--small">{{bart|slice:5}}</pre></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="title_bar">
  <img class="image" src="">
  <span class="title">{{ date }}</span>
  <span class="instance">{{ week }}</span>
</div>