#!/usr/bin/env bash
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
set -a
source <(sed 's/\r$//' "$SCRIPT_DIR/.env")
set +a
DATE_STRING=$(date +"%A, %d %B %Y")
WEEK_STRING=$(date +"Week %V")

validate_json() {
  local raw="$1"
  local fallback="$2"
  if printf '%s' "$raw" | jq empty 2>/dev/null; then
    printf '%s' "$raw"
  else
    printf '%s' "$fallback"
  fi
}

BIRTHDAYS=$(validate_json "$(./birthday/fetch)" '[]')
TASKS=$(validate_json "$(./tasks/fetch)" '[]')
WEATHER=$(validate_json "$(./weather/fetch)" '{}')

BART=$(validate_json "$(./BART/bart)" '[]')

jq -n \
  --arg greetings "Greetings from retend.app" \
  --arg date "$DATE_STRING" \
  --arg week "$WEEK_STRING" \
  --argjson birthdays "$BIRTHDAYS" \
  --argjson tasks "$TASKS" \
  --argjson weather "$WEATHER" \
  --argjson bart "$BART" '
{
  greetings: $greetings,
  date: $date,
  week: $week,
  birthdays: $birthdays,
  tasks: $tasks,
  weather: $weather,
  bart: $bart
}
' > "$PROJECT_DIRECTORY"/trmnl.json
