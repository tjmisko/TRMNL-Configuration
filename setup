#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

# ── 1. Check prerequisites ──────────────────────────────────────────
if ! command -v go &>/dev/null && [[ -x /usr/local/go/bin/go ]]; then
  export PATH="/usr/local/go/bin:$PATH"
  echo "Found go at /usr/local/go/bin/go, added to PATH"
fi

missing=()
for cmd in jq rg curl go; do
  command -v "$cmd" &>/dev/null || missing+=("$cmd")
done

if [[ ${#missing[@]} -gt 0 ]]; then
  echo "Missing required tools: ${missing[*]}"
  echo "Install them and re-run ./setup"
  exit 1
fi

# ── 2. Create .env from template ─────────────────────────────────────
if [[ ! -f .env ]]; then
  echo "Creating .env from .env.example..."
  cp .env.example .env
  sed -i "s|^PROJECT_DIRECTORY=.*|PROJECT_DIRECTORY=\"$SCRIPT_DIR\"|" .env

  default_notes="$HOME/Documents/Notes"
  read -rp "Path to notes vault [$default_notes]: " notes_dir
  notes_dir="${notes_dir:-$default_notes}"
  sed -i "s|^NOTES_DIRECTORY=.*|NOTES_DIRECTORY=\"$notes_dir\"|" .env
  sed -i 's/\r$//' .env

  echo ".env created"
else
  echo ".env already exists, skipping"
fi

# ── 3. Build BART binary ────────────────────────────────────────────
if [[ ! -f BART/bart || BART/bart.go -nt BART/bart ]]; then
  echo "Building BART binary..."
  (cd BART && go build -o bart .)
  echo "BART built"
else
  echo "BART binary is up to date"
fi

# ── 3b. Build ICS events binary ─────────────────────────────────────
if [[ ! -f events/sources/ics || events/ics/ics.go -nt events/sources/ics ]]; then
  echo "Building ICS events binary..."
  (cd events/ics && go build -o ../sources/ics .)
  echo "ICS built"
else
  echo "ICS binary is up to date"
fi

# ── 3b2. Build CSC open/close events binary ─────────────────────────
if [[ ! -f events/sources/csc || events/csc/csc.go -nt events/sources/csc ]]; then
  echo "Building CSC events binary..."
  (cd events/csc && go build -o ../sources/csc .)
  echo "CSC built"
else
  echo "CSC binary is up to date"
fi

# ── 3c. Seed events config files from their examples ────────────────
if [[ ! -f events/feeds.conf ]]; then
  cp events/feeds.conf.example events/feeds.conf
  echo "events/feeds.conf created — add your Luma/Google calendar feeds to it"
else
  echo "events/feeds.conf already exists, skipping"
fi

if [[ ! -f events/ignore.conf ]]; then
  cp events/ignore.conf.example events/ignore.conf
  echo "events/ignore.conf created — add title globs for events to hide"
else
  echo "events/ignore.conf already exists, skipping"
fi

if [[ ! -f events/csc-lessons.conf ]]; then
  cp events/csc-lessons.conf.example events/csc-lessons.conf
  echo "events/csc-lessons.conf created — set your Cal Sailing lesson windows by weekday"
else
  echo "events/csc-lessons.conf already exists, skipping"
fi

# ── 4. Ensure scripts are executable ────────────────────────────────
chmod +x update birthday/fetch tasks/fetch weather/fetch checklists/fetch \
  events/fetch events/sources/recurring
echo "Scripts marked executable"

# ── 5. Smoke test ───────────────────────────────────────────────────
echo "Running smoke test..."
if ./update && [[ -f trmnl.json ]]; then
  echo "Smoke test passed — trmnl.json written"
else
  echo "Smoke test failed — check output above"
  exit 1
fi

echo "Setup complete"
